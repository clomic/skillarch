# Config file dedicated to the user's personal aliases shared between all exegol containers
alias suc='sort|uniq -c'
alias suq='sort|uniq'
alias qs='qsv search'
alias qsh='qsv headers'
alias qsl='qsv select'
alias qsu='qsv sort -u'
alias cpy='tee >(xsel -i)'
alias cpyc='tee >(xsel -ib)'

cheat() { curl -s "cheat.sh/$1" }
alias l="eza -l --group-directories-first --icons"
alias li="eza -l --group-directories-first"
alias la="l -a"
alias laa="l -aa"
alias lgrep='grep --line-buffered'
